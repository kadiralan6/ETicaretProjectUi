{
  "permissions": {
    "allow": [
      "Read(.env*)",
      "Edit(.env*)",
      "Bash(cat *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(less *.env*)",
      "Bash(more *.env*)",
      "Grep",
      "Glob",
      "TodoRead",
      "WebFetch"
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  }
}
